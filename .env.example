# ─── DeepSeek (LLM — 故事生成与旁白) ────────────
# 默认 LLM 提供商，也可以换 Kimi 或 MiniMax
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ─── Kimi / Moonshot (LLM 备选) ───────────────
# KIMI_API_KEY=sk-xxx
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-k2.5

# ─── MiniMax (LLM 备选) ───────────────────────
# MINIMAX_API_KEY=sk-xxx
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M2.5

# ─── RunningHub (图像生成 — 默认推荐) ───────────
# 推荐后端：中文理解强，消费级 Key 可用，支持多种模型
# 注册获取 Key: https://www.runninghub.cn
# (消费级或会员 Key 均可，所有请求均需传 apiKey 参数)
RUNNINGHUB_API_KEY=your_key_here

# ─── Replicate (图像生成 — 备选) ───────────────
# 如需使用 SDXL/FLUX 云端生成可配置此 Token
# REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxx

# ─── Cloudflare R2 (对象存储 — 可选) ──────────
# 使用 python -m src.main --r2 时自动上传图片到 R2
# S3_API 格式: https://<accountid>.r2.cloudflarestorage.com/<bucket>
# R2_URL 是公开访问域名（需在 R2 面板中开启公开访问）
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY: 在 R2 → 管理 R2 API 令牌 中创建
# S3_API=https://<accountid>.r2.cloudflarestorage.com/comic
# R2_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
# R2_ACCESS_KEY_ID=your_access_key_id
# R2_SECRET_ACCESS_KEY=your_secret_access_key